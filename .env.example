# Azure OpenAI
AZURE_OPENAI_API_KEY=...
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/openai/deployments/<deployment>
AZURE_OPENAI_MODEL=gpt-5.4-mini

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Creem Payment
CREEM_API_KEY=...
CREEM_API_BASE=https://test-api.creem.io   # Test mode; production: https://api.creem.io
CREEM_WEBHOOK_SECRET=...
CREEM_PRODUCT_ID=...

# Feature Flags
PAYMENT_ENABLED=true  # Set to 'false' to disable payment UI (shows "Coming soon")
